# Production Environment Variables Template
# Copy this to .env on the server and fill in your actual values

# Database
DATABASE_URL="postgresql://franchisegate:YOUR_DB_PASSWORD@db:5432/franchisegate_db?schema=public"
DB_USER=franchisegate
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DB_NAME=franchisegate_db

# JWT - Generate a strong secret (min 32 chars)
JWT_SECRET=YOUR_JWT_SECRET_HERE_MIN_32_CHARACTERS_LONG
JWT_EXPIRES_IN=7d

# Server
NODE_ENV=production
PORT=5000

# CORS - Allowed origins
CORS_ORIGIN=https://franchisegate.sa,https://www.franchisegate.sa

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Upload Settings
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=uploads

# Frontend URL
FRONTEND_URL=https://franchisegate.sa

# Admin Account (for initial setup)
# ADMIN_EMAIL=admin@franchisegate.sa
# ADMIN_PASSWORD=your_admin_password
